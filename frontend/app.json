{
  "expo": {
    "name": "supper-at-mine-clubs",
    "slug": "supper-at-mine-clubs",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "supper-at-mine-clubs",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mayagwright20.supper-at-mine-clubs",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.mayagwright20.supperatmineclubs"
    },
    "web": {
      "output": "server",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends."
        }
      ],
      [
        "expo-router",
        {
          "origin": "https://supper-at-mine-clubs.expo.app"
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.supperatmineclubs",
          "publishableKey": "pk_test_51TbHYcPQ7WnFSQCw7wzsJUUrxkABiPiZJ6LzR3ehZP7JoobKAOyZWXs6iXVxpSlt4ZtY1WiGUQJRtUXqrGJBFX7Y00UqR4KIuW"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-video",
      "expo-font",
      "expo-web-browser",
      "@stripe/stripe-react-native",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://supper-at-mine-clubs.expo.app"
      },
      "eas": {
        "projectId": "84d9b693-f001-457d-baa6-809a9ee88478"
      }
    }
  }
}
